# ─────────────────────────────────────────────────────────────────────────────
# ParticipateHere Backend — Environment Variables Template
# Copy this file, rename to .env, and fill in the real values.
# On Railway/Render: paste these as Environment Variables in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (Railway sets PORT automatically, leave as is)
PORT=8086

# MySQL Database (use Railway MySQL plugin → copy the values from its dashboard)
SPRING_DATASOURCE_URL=jdbc:mysql://<host>:<port>/<database>
SPRING_DATASOURCE_USERNAME=<db_user>
SPRING_DATASOURCE_PASSWORD=<db_password>

# JWT Secret — use a long random string (min 64 chars)
APP_JWT_SECRET=replace_this_with_a_very_long_random_secret_at_least_64_characters

# JWT Expiry (milliseconds) — 600000 = 10 min, 604800000 = 7 days
APP_JWT_EXPIRATION_MS=600000
APP_JWT_REFRESH_EXPIRATION_MS=604800000

# Gmail SMTP (use a Gmail App Password, NOT your real Gmail password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# CORS — your deployed Vercel frontend URL
# If multiple URLs needed, separate with comma: https://app.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
